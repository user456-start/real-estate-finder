# Deployment Configuration for Dubai Real Estate Finder

# ─── Anthropic API ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ─── Database ────────────────────────────────────────────────────────────
# Used by backend to connect to PostgreSQL
DATABASE_URL=postgresql://realestate_user:realestate_pass@db:5432/realestate_db

# ─── Vector Database ─────────────────────────────────────────────────────
# Qdrant for semantic search on property listings and area guides
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_LISTINGS=listings
QDRANT_COLLECTION_AREA_GUIDES=area_guides

# ─── Cache ───────────────────────────────────────────────────────────────
# Redis for session caching and async job queues
REDIS_URL=redis://redis:6379

# ─── Embeddings (Hugging Face, free tier) ────────────────────────────────
# Get token at: huggingface.co → Settings → Access Tokens → New token (read)
# Free tier: 30,000 requests/month
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# ─── RapidAPI (Optional - for image scraping) ────────────────────────────
# RAPIDAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# RAPIDAPI_HOST=realtor.p.rapidapi.com

# ─── Email (Optional - for daily digest) ────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# DIGEST_EMAIL_TO=recipient@gmail.com

# ─── Frontend ─────────────────────────────────────────────────────────────
# Public API URL (used by browser)
NEXT_PUBLIC_API_URL=http://localhost:8001
