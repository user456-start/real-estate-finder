# ── Database ──────────────────────────────────────────────────────────────────
# Port 5433 because 5432 is occupied by the observability platform DB
DATABASE_URL=postgresql://realestate_user:realestate_pass@localhost:5433/realestate_db

# ── Redis (POI cache) ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0

# ── Qdrant (vector store) ─────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── Ollama (local, free) ──────────────────────────────────────────────────────
# Make sure Ollama is running: https://ollama.com/download
# Pull models once:
#   ollama pull llama3.2           ← chat / generation (~2 GB)
#   ollama pull nomic-embed-text   ← embeddings, 768-dim (~274 MB)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── External APIs ─────────────────────────────────────────────────────────────
GEOAPIFY_API_KEY=your_geoapify_key_here

# ── Email — Gmail SMTP ────────────────────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google account
# 2. Go to myaccount.google.com/apppasswords
# 3. Create an App Password for "Mail" → copy the 16-char code below
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_TO=you@gmail.com

# ── Observability (llm-observer SDK → electronics backend) ────────────────────
LLM_OBSERVER_URL=http://localhost:8000
LLM_OBSERVER_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8001
DEBUG=true
