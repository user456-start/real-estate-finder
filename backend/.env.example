# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://realestate_user:realestate_pass@localhost:5433/realestate_db

# ── Redis (POI cache) ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0

# ── Qdrant (vector store) ─────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── Embeddings (Hugging Face - nomic-embed-text via sentence-transformers) ────
# The embedding model will be downloaded automatically on first use (~375 MB)
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# ── External APIs ─────────────────────────────────────────────────────────────
GEOAPIFY_API_KEY=your_geoapify_key_here
RAPIDAPI_KEY=your_rapidapi_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Email — Gmail SMTP ────────────────────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google account
# 2. Go to myaccount.google.com/apppasswords
# 3. Create an App Password for "Mail" → copy the 16-char code below
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_TO=you@gmail.com

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8001
DEBUG=true
